    "@id": "https://www.w3.org/ns/lws#",
    "@type": "owl:Ontology",
    "dc:title": {
        "@value": "Linked Web Storage Vocabulary",
        "@language": "en"
    },
    "dc:description": {
        "@value": "RDFS [[RDF-SCHEMA]] vocabulary used by the Linked Web Storage Protocol [[lws-protocol]]",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
    },
    "rdfs:seeAlso": "https://www.w3.org/TR/lws-protocol/",
    "dc:date": "2026-03-29",
    "rdfs_properties": [{
        "@id": "lws:items",
        "@type": "rdf:Property",
        "rdfs:domain": "lws:Container",
        "rdfs:label": "items",
        "rdfs:comment": {
            "@value": "<div>The list of resources contained in a container.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "lws:capability",
        "@type": "rdf:Property",
        "rdfs:domain": "lws:Storage",
        "rdfs:label": "capability",
        "rdfs:comment": {
            "@value": "<div>A capability supported by the storage.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "lws:service",
        "@type": "rdf:Property",
        "rdfs:domain": "lws:Storage",
        "rdfs:label": "service",
        "rdfs:comment": {
            "@value": "<div>A service associated with the storage.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "lws:serviceEndpoint",

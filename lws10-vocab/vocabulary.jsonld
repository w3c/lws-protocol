        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "lws:storageDescription",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "storage description",
        "rdfs:comment": {
            "@value": "<div>Link relation pointing to a storage description resource.</div>",

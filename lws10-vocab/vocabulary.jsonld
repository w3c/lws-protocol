        "@type": "rdf:Property",
        "rdfs:label": "Prefer Link Relations",
        "rdfs:comment": {
            "@value": "<div>A preference URI for including or omitting specific link relations in responses.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }],
